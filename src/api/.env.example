# Required in every environment.
APP_ENV=development

# Database path defaults (logical name → physical resolution from src/api/):
#   development → data/dev.sqlite3 → ../../data/dev.sqlite3
#   production  → data/production.sqlite3 → ../../data/production.sqlite3
# Both resolve to the repository-root data/ directory when running from src/api/.
# Override with SQLITE_DB_PATH (absolute path for persistent volume deployment).
SQLITE_DB_PATH=../../data/dev.sqlite3

# Production deployment example:
# APP_ENV=production
# SQLITE_DB_PATH=/var/lib/ecommerce/production.sqlite3
